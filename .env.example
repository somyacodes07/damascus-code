# =============================================================================
# Damascus Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
DAMASCUS_ENV=development
DAMASCUS_DEBUG=true
DAMASCUS_LOG_LEVEL=debug

# --- Server ---
DAMASCUS_SERVER_HOST=0.0.0.0
DAMASCUS_SERVER_PORT=8000

# --- Database (PostgreSQL) ---
DAMASCUS_DATABASE_URL=postgresql+asyncpg://damascus:damascus_dev@localhost:5432/damascus

# --- Redis ---
DAMASCUS_REDIS_URL=redis://localhost:6379

# --- Qdrant ---
DAMASCUS_QDRANT_URL=http://localhost:6333

# --- NATS ---
DAMASCUS_NATS_URL=nats://localhost:4222

# --- MinIO ---
DAMASCUS_STORAGE_ENDPOINT=localhost:9000
DAMASCUS_STORAGE_ACCESS_KEY=damascus
DAMASCUS_STORAGE_SECRET_KEY=damascus_dev
DAMASCUS_STORAGE_BUCKET=damascus

# --- Model Providers (fill in only what you use) ---
# Ollama (recommended for local development — no key required)
DAMASCUS_MODELS_OLLAMA_ENABLED=true
DAMASCUS_MODELS_OLLAMA_ENDPOINT=http://localhost:11434
DAMASCUS_MODELS_OLLAMA_DEFAULT_MODEL=llama3.1

# OpenAI
DAMASCUS_MODELS_OPENAI_ENABLED=false
# DAMASCUS_MODELS_OPENAI_API_KEY=sk-...

# Anthropic
DAMASCUS_MODELS_ANTHROPIC_ENABLED=false
# DAMASCUS_MODELS_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
DAMASCUS_MODELS_GEMINI_ENABLED=false
# DAMASCUS_MODELS_GEMINI_API_KEY=...

# OpenRouter
DAMASCUS_MODELS_OPENROUTER_ENABLED=false
# DAMASCUS_MODELS_OPENROUTER_API_KEY=...

# --- Security ---
DAMASCUS_SECURITY_SECRET_KEY=change-this-to-a-random-secret-in-production
DAMASCUS_SECURITY_REQUIRE_APPROVAL_FOR_TOOLS=true
DAMASCUS_SECURITY_SANDBOX_ENABLED=true
DAMASCUS_SECURITY_AUDIT_ENABLED=true

# --- Evolution ---
DAMASCUS_EVOLUTION_ENABLED=false
DAMASCUS_EVOLUTION_AUTO_PROMOTE=false
DAMASCUS_EVOLUTION_MAX_CONCURRENT_EXPERIMENTS=3

# --- Observability ---
DAMASCUS_OBSERVABILITY_TRACING_ENABLED=true
DAMASCUS_OBSERVABILITY_METRICS_ENABLED=true
